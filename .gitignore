node_modules/
dist/
apps/desktop/web-dist/
apps/desktop/web/vendor/
apps/desktop/web/public/vendor/
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/
# Cloudflare Pages publish dir — only the source files (_headers, index.html)
# are tracked. Build artifacts get copied in by `pnpm build:pages` on deploy.
public/SRI.json
public/agent-pet*.js
public/pet.css
public/index.d.ts
public/core/
public/react/
public/widget/
public/v*/
public/version.json

# Rich editor — build artefacts + dev server saves.
tools/rich-editor/build/
tools/rich-editor/saves/*.json
tools/rich-editor/rips/
tools/rich-editor/serve.log
# Promoted preset content IS tracked (shared authored data) but the
# regenerated index lives at runtime — ignore it so it doesn't churn.
tools/rich-editor/presets/index.json

# Windows NTFS alternate-data-stream metadata (created when files come
# from a downloaded zip / browser).
*:Zone.Identifier
