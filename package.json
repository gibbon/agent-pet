{
  "name": "agent-pet",
  "version": "0.10.0",
  "description": "Tiny animated companion-pet widget for any web app. Self-hosted, no backend, ~10 KB gzip vanilla DOM. Drives 9 distinct atlas animations from a simple JS API.",
  "keywords": [
    "widget",
    "pet",
    "companion-pet",
    "spritesheet",
    "pixel-art",
    "codex-pets",
    "shadow-dom",
    "vanilla-dom",
    "react"
  ],
  "homepage": "https://agent-pet.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gibbon/agent-pet.git"
  },
  "bugs": {
    "url": "https://github.com/gibbon/agent-pet/issues"
  },
  "author": "Tom D",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": [
    "./dist/pet.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/agent-pet.js",
      "types": "./dist/index.d.ts"
    },
    "./widget": {
      "import": "./dist/agent-pet-widget.es.js",
      "types": "./dist/widget/widget-es.d.ts"
    },
    "./iife": "./dist/agent-pet-widget.iife.js",
    "./css": "./dist/pet.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && vite build --mode widget && vite build --mode widget-esm && vite build --mode rich && node scripts/sri.mjs",
    "build:pages": "pnpm build && node scripts/build-pages.mjs",
    "build:es": "vite build",
    "build:widget": "vite build --mode widget",
    "build:widget-esm": "vite build --mode widget-esm",
    "build:rich": "vite build --mode rich",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "vendor-pet": "node scripts/vendor-pet.mjs",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
