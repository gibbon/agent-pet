# Root path (latest): short cache so breaking changes propagate quickly.
/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300

# Versioned paths (e.g. /v0.1/, /v1/, /v2/): immutable, long cache.
# Pin to a versioned URL in production for stability + cacheability.
/v*/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable
